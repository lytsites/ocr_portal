# Runtime settings for PDF table extraction
KEEP_TEMP_ARTIFACTS=true
WORKER_COUNT=6
WORKER_IDLE_SLEEP_SEC=0.5
BATCH_TIMER_ENABLED=true

# Comma-separated allowed frontend origins for backend CORS.
